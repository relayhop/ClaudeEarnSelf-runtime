{
  "version": 1,
  "date": "2026-05-09",
  "source": "Derived from gumroad.com/prohibited (54 items) + ToS sections; only items relevant to digital-product creators included.",
  "match_mode": "case_insensitive_word_boundary",
  "false_positive_note": "Patterns aim for high recall on listing names/descriptions. Some FPs expected (e.g. 'crypto' in unrelated context). Reviewer should sanity-check before takedown.",
  "rules": [
    {"id": "GP15", "layer": 1, "rule": "copyrighted_media_or_software", "severity": "high",
     "patterns": ["\\bmarvel\\b", "\\bdisney\\b", "\\bnintendo\\b", "\\bpok[eé]mon\\b", "\\bnaruto\\b", "\\bone piece\\b", "\\bgenshin( impact)?\\b", "\\bharry potter\\b", "\\bnetflix\\b", "\\bhbo\\b", "\\bspotify\\b", "\\badobe (photoshop|illustrator|premiere|after effects)\\b(?! brush| preset| template| tutorial| course)", "\\b(microsoft|windows) (office|word|excel|11|10) (key|crack|activator|license)\\b", "\\bhelldivers\\b", "\\bzelda\\b", "\\bstar wars\\b", "\\bcracked\\b", "\\bnulled\\b", "\\bpirated\\b"]},
    {"id": "GP16", "layer": 1, "rule": "counterfeit_or_unauthorized", "severity": "high",
     "patterns": ["\\b(louis vuitton|gucci|chanel|hermes|rolex|patek philippe) replica\\b", "\\bfake (autograph|signature)\\b", "\\bcounterfeit\\b", "\\breplica designer\\b"]},
    {"id": "GP19", "layer": 1, "rule": "crypto_or_NFT_products", "severity": "medium",
     "patterns": ["\\b(buy|sell|trade) (bitcoin|ethereum|solana)\\b", "\\bnft (mint|drop|airdrop)\\b", "\\bairdrop\\b(?! design| brush)", "\\b(altcoin|memecoin|shitcoin)\\b", "\\bcrypto signal(s)?\\b", "\\bweb3 launch\\b", "\\bicop\\b", "\\bico (whitepaper|launch)\\b"]},
    {"id": "GP23", "layer": 1, "rule": "essay_or_paper_mills", "severity": "medium",
     "patterns": ["\\bessay writing service\\b", "\\bpaper writing service\\b", "\\bhomework done for you\\b", "\\bdissertation writing service\\b", "\\bghostwrit(e|ing) academic\\b"]},
    {"id": "GP27", "layer": 1, "rule": "fortune_tellers", "severity": "low_due_to_patchy_enforcement",
     "patterns": ["\\btarot reading\\b", "\\bfortune tell(er|ing)\\b", "\\bpsychic reading\\b", "\\bpalm read(ing)?\\b", "\\bastrology personalized\\b", "\\bbirth chart reading\\b", "\\bclairvoyant\\b"]},
    {"id": "GP30", "layer": 1, "rule": "hacking_cracking_materials", "severity": "high",
     "patterns": ["\\bkeylogger\\b", "\\bmalware\\b", "\\bexploit kit\\b", "\\b(0|zero).?day\\b", "\\bcrack(ing)? (tutorial|guide)\\b", "\\b(wifi|wpa) crack(er|ing)?\\b", "\\bphishing kit\\b", "\\b(carding|cc dump)\\b", "\\brat (builder|toolkit)\\b"]},
    {"id": "GP41", "layer": 1, "rule": "pseudo_pharmaceuticals", "severity": "high",
     "patterns": ["\\b(weight loss|diet) pill(s)?\\b", "\\b(anti|reverse).?aging (pill|supplement|cream)\\b", "\\bsexual stimulant\\b", "\\b(libido|testosterone|growth hormone) booster\\b", "\\bmiracle (cure|pill)\\b", "\\bfat burner\\b", "\\b(detox|cleanse) (pill|kit)\\b"]},
    {"id": "GP43", "layer": 1, "rule": "PLR_reselling", "severity": "medium",
     "patterns": ["\\bprivate label rights\\b", "\\bplr (pack|ebook|content|articles?)\\b", "\\bresell (rights|license)\\b", "\\bmaster resell rights\\b", "\\bmrr (pack|bundle)\\b"]},
    {"id": "GP44_45", "layer": 1, "rule": "investment_brokerage_get_rich_quick", "severity": "medium",
     "patterns": ["\\bget rich (quick|fast)\\b", "\\bguaranteed (return|profit|income)\\b", "\\bmake \\$\\d+k? (per |a |/)?(day|week|month)\\b", "\\b(stock|forex|crypto) signal(s)?\\b", "\\binsider (trading|tip)\\b", "\\bmortgage reduction\\b", "\\bcredit repair (system|service)\\b", "\\bpassive income guaranteed\\b", "\\briskless\\b"]},
    {"id": "GP46", "layer": 1, "rule": "sexually_oriented_or_dating", "severity": "high",
     "patterns": ["\\bporn(ography|ographic|star)?\\b", "\\bnude (photo|model)\\b", "\\bescort service\\b", "\\bsugar (daddy|baby|momma)\\b", "\\bonlyfans\\b", "\\bmail.order bride(s)?\\b", "\\bmassage parlor\\b", "\\bdating app\\b", "\\bxxx\\b", "\\b(bdsm|fetish) (guide|content)\\b"]},
    {"id": "GP14", "layer": 1, "rule": "consulting_firms", "severity": "low",
     "patterns": ["\\b(1-on-1|one-on-one|1:1) consulting\\b", "\\bconsulting (firm|agency)\\b", "\\bbook (a |my )?consultation\\b"]},
    {"id": "GP31", "layer": 1, "rule": "explicitly_illegal", "severity": "high",
     "patterns": ["\\bsteal(ing)? (account|password|identity)\\b", "\\bdoxx?ing (guide|service)\\b", "\\bbypass (paywall|drm|copy protection)\\b"]},
    {"id": "ESI_FDA", "layer": 2, "rule": "FDA_FTC_disease_cure_claims", "severity": "high",
     "patterns": ["\\bcure(s)? (cancer|diabetes|depression|alzheimer|adhd|autism|covid|herpes|hiv|aids)\\b", "\\breverse(s)? (aging|diabetes|alzheimer)\\b", "\\bclinically proven to (cure|reverse|eliminate)\\b", "\\b100% guaranteed (cure|treatment)\\b", "\\bmiraculous healing\\b"]},
    {"id": "ESI_SEC", "layer": 2, "rule": "individualized_financial_advice", "severity": "medium",
     "patterns": ["\\bguaranteed (roi|return on investment)\\b", "\\b(double|triple) your money\\b", "\\bsecret (stock|crypto) pick\\b", "\\bbuy now: \\$[A-Z]{2,5}\\b"]},
    {"id": "ESI_REFUND", "layer": 2, "rule": "high_refund_risk_proxy", "severity": "low",
     "patterns": [],
     "note": "Implemented as composite_score penalty using same-tag avg_rating < 3.5; no keyword regex"}
  ]
}
